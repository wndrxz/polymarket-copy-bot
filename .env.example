# ─── Mode ──────────────────────────────────────────
DRY_RUN=true
MOCK_SIGNALS=true
LOG_LEVEL=INFO

# ─── Capital ─────────────────────────────────────────
STARTING_BALANCE=1000

# ─── Risk Limits ─────────────────────────────────────
MAX_EXPOSURE_PCT=30
MAX_POSITION_PCT=15
MAX_POSITIONS=10
STOP_LOSS_PCT=15
TAKE_PROFIT_PCT=50
DAILY_LOSS_LIMIT_PCT=10
DRAWDOWN_HALT_PCT=25
TRADE_COOLDOWN_MS=30000
MIN_PRICE=0.05
MAX_PRICE=0.95
MIN_LIQUIDITY=1000
MIN_TRADER_SCORE=40

# ─── Intervals (ms) ─────────────────────────────────
SIGNAL_INTERVAL_MS=10000
PRICE_UPDATE_INTERVAL_MS=5000
RISK_CHECK_INTERVAL_MS=3000
REPORT_INTERVAL_MS=60000
PERSIST_INTERVAL_MS=30000

# ─── Target Traders (comma-separated addresses) ─────
TARGET_TRADERS=

# ─── Polymarket API ─────────────────────────────────
CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com